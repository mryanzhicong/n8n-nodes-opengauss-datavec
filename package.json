{
  "name": "n8n-nodes-opengauss-datavec",
  "version": "0.1.0",
  "description": "n8n community node for openGauss DataVec vector database",
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "opengauss",
    "datavec",
    "vector",
    "vector-database",
    "similarity-search"
  ],
  "license": "MIT",
  "author": "yanzhicong",
  "homepage": "https://github.com/mryanzhicong/n8n-nodes-opengauss-datavec#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mryanzhicong/n8n-nodes-opengauss-datavec.git"
  },
  "bugs": {
    "url": "https://github.com/mryanzhicong/n8n-nodes-opengauss-datavec/issues"
  },
  "engines": {
    "node": ">=20.15"
  },
  "main": "dist/nodes/VectorStoreOpenGauss/VectorStoreOpenGauss.node.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && copyfiles \"nodes/**/*.svg\" dist/",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/OpenGaussDataVec.credentials.js"
    ],
    "nodes": [
      "dist/nodes/VectorStoreOpenGauss/VectorStoreOpenGauss.node.js"
    ]
  },
  "dependencies": {
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@types/pg": "^8.10.0",
    "@types/node": "^20.0.0",
    "n8n-workflow": "*",
    "typescript": "^5.3.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "eslint": "^8.56.0",
    "copyfiles": "^2.4.1"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
